# ------------------------------------------------------------
# The istioctl binary is ~106 MB (over GitHub's 100 MB limit).
# setup.bat downloads it automatically into tools/bin, so we
# never commit it. Anyone cloning just runs setup.bat.
# ------------------------------------------------------------
tools/
istio-*/
istioctl.zip
*.exe

# scratch / temp
_tmp_*
*.tmp
*.log
tmp.json

# OS cruft
Thumbs.db
Desktop.ini
.DS_Store
